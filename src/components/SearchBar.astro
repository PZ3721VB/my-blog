<div class="search-wrapper">
  <span class="search-icon">🔍</span>
  <input
    type="text"
    class="search-input"
    id="searchInput"
    placeholder="搜索文章..."
    autocomplete="off"
  />
</div>
<div id="searchResults">
  <ul class="post-list" id="searchList"></ul>
</div>

<script>
  interface SearchItem {
    title: string;
    description: string;
    slug: string;
    tags: string[];
    category: string;
    pubDate: string;
  }

  let searchData: SearchItem[] = [];
  let loaded = false;

  async function loadSearchData() {
    if (loaded) return;
    try {
      const res = await fetch('/search.json');
      searchData = await res.json();
      loaded = true;
    } catch (e) {
      console.error('Failed to load search data:', e);
    }
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function highlightMatch(text: string, query: string): string {
    const escaped = escapeHtml(text);
    const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return escaped.replace(regex, '<mark>$1</mark>');
  }

  function search(query: string): SearchItem[] {
    if (!query.trim()) return [];
    const q = query.toLowerCase();
    return searchData.filter(
      (item) =>
        item.title.toLowerCase().includes(q) ||
        item.description.toLowerCase().includes(q) ||
        item.tags.some((t) => t.toLowerCase().includes(q)) ||
        item.category.toLowerCase().includes(q)
    );
  }

  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const searchList = document.getElementById('searchList')!;
  const originalList = document.querySelector<HTMLElement>('.post-list:not(#searchList)');

  searchInput?.addEventListener('input', async () => {
    await loadSearchData();
    const query = searchInput.value.trim();

    if (!query) {
      // Show original post list, hide search results
      searchList.innerHTML = '';
      searchList.style.display = 'none';
      if (originalList) originalList.style.display = '';
      // Remove any "results count" text
      const countEl = document.getElementById('searchCount');
      if (countEl) countEl.remove();
      return;
    }

    const results = search(query);

    // Hide original list
    if (originalList) originalList.style.display = 'none';
    searchList.style.display = '';

    // Show count
    let countEl = document.getElementById('searchCount');
    if (!countEl) {
      countEl = document.createElement('p');
      countEl.id = 'searchCount';
      countEl.className = 'search-results-count';
      searchList.parentNode?.insertBefore(countEl, searchList);
    }
    countEl.textContent = `找到 ${results.length} 篇相关文章`;

    if (results.length === 0) {
      searchList.innerHTML = '<div class="no-results"><p>😕 没有找到相关文章，试试其他关键词吧</p></div>';
      return;
    }

    searchList.innerHTML = results
      .map(
        (item) => `
        <li>
          <a href="/blog/${item.slug}" class="post-card">
            <h2 class="post-card-title">${highlightMatch(item.title, query)}</h2>
            <p class="post-card-description">${highlightMatch(item.description, query)}</p>
            <div class="post-card-meta">
              <span>📅 ${new Date(item.pubDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
              ${item.tags.length ? '<span>🏷️ ' + item.tags.slice(0, 3).map(t => highlightMatch(t, query)).join(' · ') + '</span>' : ''}
            </div>
          </a>
        </li>`
      )
      .join('');
  });
</script>
