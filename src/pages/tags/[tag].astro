---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPostsByTag, getTagCounts } from '../../utils/posts';

export async function getStaticPaths() {
  const tagCounts = await getTagCounts();
  return [...tagCounts.keys()].map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;
const posts = await getPostsByTag(tag!);
---

<BaseLayout title={`标签: ${tag}`} description={`查看所有标记为「${tag}」的文章`}>
  <header class="page-header">
    <h1 class="page-title">🏷️ #{tag}</h1>
    <p class="page-description">
      共 {posts.length} 篇文章
    </p>
    <a href="/tags" style="font-size: 0.9rem;">← 查看所有标签</a>
  </header>

  {
    posts.length === 0 ? (
      <div class="empty-state">
        <p>该标签下暂无文章</p>
      </div>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <PostCard {post} />
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
